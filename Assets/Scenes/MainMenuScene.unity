      m_Calls: []
  m_text: "At the start of certain battles a random <b>weather condition</b> is set.
    Weather affects all Pok\xE9mon on the field for the entire battle.\n\n\n<b>Sun</b>
    \u2014 Fire-type moves deal bonus damage. Water-type moves deal reduced damage.\n\n<b>Rain</b>
    \u2014 Water-type moves deal bonus damage. Fire-type moves deal reduced damage.\n\n<b>Sandstorm</b>
    \u2014 Ground types are unaffected. All others lose HP each round unless they
    have a protective ability."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: b3e572049d233d8409cf8cbe7178c585, type: 2}
